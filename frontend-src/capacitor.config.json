{
  "appId": "ai.mindlab.app",
  "appName": "Mindlab",
  "webDir": "out",
  "server": {
    "url": "https://frontend-src-liart.vercel.app",
    "cleartext": false
  },
  "ios": {
    "contentInset": "automatic",
    "scheme": "Mindlab"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    }
  }
}
